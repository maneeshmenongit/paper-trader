# LLM providers (same keys as oracle-agents)
GROQ_API_KEY=
GEMINI_API_KEY=

# Market data
FINNHUB_API_KEY=

# Paths — four+ stores, four+ connection paths, never co-mingled
PAPER_TRADER_DB_PATH=./data/paper_trader.sqlite
CHECKPOINTER_DB_PATH=./data/checkpointer.sqlite
# Governance stores (framework-shaped, app-scoped)
SKILL_REGISTRY_DB_PATH=./data/skills.sqlite
# Store A — execution trace (Wave 3 emission).
STORE_A_DB_PATH=./data/store_a.sqlite
# Store B — correction ledger (Wave 4). Observer writes (append-only); proposer reads.
STORE_B_DB_PATH=./data/store_b.sqlite
# Proposal store (Wave 4). Proposer writes PROPOSED records; the gate/fork is Wave 5.
PROPOSALS_DB_PATH=./data/proposals.sqlite

# Cycle behavior
CYCLE_TIME_HORIZON_HOURS=24
CYCLE_TOKEN_BUDGET=15000
CYCLE_LOG_LEVEL=INFO

# ─── Live operation (Live-Operation T3) ──────────────────────────────────
# The fakes→live swap. Off by default: an unconfigured run / CI stays offline.
PAPER_TRADER_LIVE_MODE=0
# Watchlist Filter validates each cycle (determines whether R2 floors bind).
PAPER_TRADER_WATCHLIST_PATH=./config/watchlist.toml
# Open-source LLM for Research + PostMortem bias-tagging: ollama | openrouter.
PAPER_TRADER_LLM_PROVIDER=ollama
# Self-hosted Ollama (no key).
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
# Hosted open-weight (no-hardware path). Needs OPENROUTER_API_KEY when selected.
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
OPENROUTER_API_KEY=
# REASONING TIER (judgment-heavy purposes, e.g. Stage-1 predict_selection). Routed
# SEPARATELY from the fast tier above so a strong model handles selection while the
# fast/local model handles Research/PostMortem. Empty → reasoning reuses the fast
# tier. Provider: groq | gemini | ollama | openrouter (needs that provider's key).
PAPER_TRADER_REASONING_PROVIDER=groq
# Optional explicit model; empty → the provider's default (groq: llama-3.3-70b).
PAPER_TRADER_REASONING_MODEL=
# NOTE: keys/endpoints above are config/secrets — NEVER frozen into the trace
# (DT-4.2 MUST-NOT-freeze). Groq/Gemini keys serve as the LLM fallback chain.
